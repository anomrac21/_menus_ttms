{{ warnf "Generating JSON file for Home Page: %s" .Title }}
{{- with .Site.Home }}

  {{- $images := slice -}}
  {{- range .Params.images }}
    {{- $images = $images | append (dict "image" .image) -}}
  {{- end }}

  {{- $slideshowImages := slice -}}
  {{- range .Params.slideshow }}
    {{- $slideshowImages = $slideshowImages | append (dict "image" .image) -}}
  {{- end }}

  {{- $locations := slice -}}
  {{- with site.Data.locations.locations }}
    {{- range . }}
      {{- $locationData := dict
          "address"  .address
          "city"     .city
          "island"   .island
          "subcategories"  .subcategories
          "orderingtables" .orderingtables
          "latlon"    .latlon
          "phone"    .phone
          "whatsapp" .whatsapp
          "delivery" .delivery
          "opening_hours" .opening_hours
        -}}
      {{- $locations = $locations | append $locationData -}}
    {{- end }}
  {{- end }}

  {{- $social := dict -}}
  {{- with .Params.facebook }}{{ $social = merge $social (dict "facebook" .) }}{{ end }}
  {{- with .Params.instagram }}{{ $social = merge $social (dict "instagram" .) }}{{ end }}
  {{- with .Params.youtube }}{{ $social = merge $social (dict "youtube" .) }}{{ end }}
  {{- with .Params.tiktok }}{{ $social = merge $social (dict "tiktok" .) }}{{ end }}
  
  {{- $f := site.Params.features | default dict -}}
  {{- $payments := default false $f.payments -}}
  {{- $delivery := default false $f.delivery -}}
  {{- $notifications := default false $f.notifications -}}
  {{- $pos := false -}}
  {{- $posProvider := "" -}}
  {{- with site.Params.posintegration -}}
    {{- if .enabled -}}
      {{- $pos = true -}}
      {{- with .provider -}}{{- $posProvider = . -}}{{- end -}}
    {{- end -}}
  {{- end -}}
  {{- $analytics := or (default false $f.analytics_access) (default false $f.analytics) -}}
  {{- with site.Params.services -}}
    {{- if gt (int (default 0 .analyticsid)) 0 -}}{{- $analytics = true -}}{{- end -}}
  {{- end -}}
  {{- $exclusiveAds := default false $f.exclusive_ads -}}
  {{- if not $exclusiveAds -}}{{- $exclusiveAds = default false $f.no_competitor_ads -}}{{- end -}}
  {{- $features := dict
      "payments" $payments
      "delivery" $delivery
      "notifications" $notifications
      "pos" $pos
      "analytics" $analytics
      "exclusive_ads" $exclusiveAds
      "featured" (default false $f.featured)
      "no_competitor_ads" (default false $f.no_competitor_ads)
      "unmetered_traffic" (default false $f.unmetered_traffic)
  -}}
  {{- if and $pos (ne (strings.TrimSpace $posProvider) "") -}}
    {{- $features = merge $features (dict "pos_provider" (lower (strings.TrimSpace $posProvider))) -}}
  {{- end -}}

  {{- $tier := default "free" site.Params.tier -}}
  {{- $freeMenu := eq $tier "free" -}}

  {{- $mappin := site.Data.mappin | default dict -}}

  {{- $json := dict
      "title" .Title
      "tier" $tier
      "free_menu" $freeMenu
      "paid_menu" (not $freeMenu)
      "hero_background_image" (.Params.image | default "")
      "featured_images" $images
      "slideshow" $slideshowImages
      "client_tour_images" $slideshowImages
      "locations" $locations
      "social_links" $social
      "features" $features
      "categories"  (.Params.categories | default "")
      "tags" (.Params.tags | default slice)
      "type" (.Params.type | default slice)
      "content" (.Content | default "")
      "mappin" $mappin
  -}}

  {{ $json | jsonify }}

{{- end }}
